# Cloudflare Pages proxy: forward /api and /uploads to backend
# 部署后将 https://your-backend.railway.app 替换为实际后端地址
/api/*  https://your-backend.railway.app/api/:splat  200
/uploads/*  https://your-backend.railway.app/uploads/:splat  200

